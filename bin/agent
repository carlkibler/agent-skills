#!/usr/bin/env bash
# Multi-provider model CLI for agents and skills.
# Canonical source lives in the agent-skills repo (bin/agent). Synced to
# ~/.local/bin/agent by scripts/install_bin.sh; that copy wins on PATH and
# owes nothing to ~/.claude. env bash picks up a modern bash; the array
# guards below also keep it safe under macOS stock /bin/bash 3.2.
#
# Routing philosophy (cheap-first):
#   - Default to cheap, fast, increasingly-capable models for daily work.
#   - Route to a provider's DIRECT API when its key exists (cheaper than
#     the same model resold through OpenRouter), falling back to OpenRouter.
#   - Prefer a locally-authenticated subscription CLI (claude/codex) for
#     premium models — no per-token cost — before paying OpenRouter for them.
#   - Default + --frontier use the on-device codex subscription (free); Opus is
#     explicit-only (--model opus) since it's the expensive OpenRouter path.
#   - A credential that exists but is REJECTED (e.g. a stale Gemini key) is
#     detected and skipped, not silently trusted — the next route takes over.
#
# Browse OpenRouter models: https://openrouter.ai/models
set -euo pipefail

source ~/.secrets 2>/dev/null || true

# ============================================================================
# PROVIDERS — direct OpenAI-compatible /chat/completions endpoints + key env.
# Add a provider here and reference it in the routing table below.
# ============================================================================
provider_base_url() {
    case "$1" in
        deepseek)   echo "https://api.deepseek.com/chat/completions" ;;
        zai)        echo "https://api.z.ai/api/paas/v4/chat/completions" ;;
        openrouter) echo "https://openrouter.ai/api/v1/chat/completions" ;;
        *)          echo "" ;;
    esac
}
provider_key_env() {
    case "$1" in
        deepseek)   echo "DEEPSEEK_API_KEY" ;;
        zai)        echo "ZAI_API_KEY" ;;
        openrouter) echo "OPENROUTER_API_KEY" ;;
        *)          echo "" ;;
    esac
}
# Transport: "http" providers POST an OpenAI-compatible endpoint; "cli"
# providers shell out to a locally-authenticated tool (Claude/ChatGPT
# subscription) so premium models cost nothing per token.
provider_transport() {
    case "$1" in
        claude_cli|codex_cli) echo "cli" ;;
        *)                    echo "http" ;;
    esac
}

# ============================================================================
# PRICING — per MILLION tokens, "INPUT OUTPUT", for the cost readout.
# Best-effort and editable. Unknown -> readout shows tokens only, no $.
# Keyed by "provider|model". Update as prices move.
# ============================================================================
price_for() {
    case "$1" in
        deepseek\|deepseek-v4-flash)              echo "0.14 0.28" ;;
        deepseek\|deepseek-v4-pro)                echo "0.43 0.87" ;;
        openrouter\|deepseek/deepseek-v4-flash)   echo "0.20 0.40" ;;
        openrouter\|deepseek/deepseek-v4-pro)     echo "0.55 1.10" ;;
        zai\|glm-5.2|openrouter\|z-ai/glm-5.2)    echo "0.94 3.00" ;;
        zai\|glm-5.1|zai\|glm-4.7|zai\|glm-4.6)   echo "0.60 2.00" ;;
        codex_cli\|*|claude_cli\|*)               echo "0 0" ;;  # subscription, no per-token cost
        openrouter\|anthropic/claude-opus-4.8|openrouter\|~anthropic/claude-opus-latest) echo "5.00 25.00" ;;
        openrouter\|~anthropic/claude-sonnet-latest) echo "3.00 15.00" ;;
        openrouter\|x-ai/grok-4.3)                echo "1.25 2.50" ;;
        openrouter\|~openai/gpt-latest)           echo "5.00 30.00" ;;
        *)                                        echo "" ;;
    esac
}

# ============================================================================
# ROUTING — a selector resolves to an ORDERED list of "provider|model"
# candidates. The engine tries them in order: skips routes whose key is
# unset, retries transient failures with backoff, and falls through to the
# next candidate on hard failure (bad/rejected key, model unavailable).
# First candidate = preferred (cheapest capable + direct provider when possible).
# ============================================================================
resolve_routes() {
    case "$1" in
        # --- capability tiers ---
        tier:default)   # on-device codex subscription (free), GLM-5.2 fallback
            echo "codex_cli|"
            echo "openrouter|z-ai/glm-5.2"
            ;;
        tier:fast)      # literally fast + cheap for bulk/high-volume (codex exec is slow)
            echo "deepseek|deepseek-v4-flash"
            echo "openrouter|deepseek/deepseek-v4-flash"
            ;;
        tier:smart)     # strong reasoning, still cheap
            echo "zai|glm-5.2"
            echo "deepseek|deepseek-v4-pro"
            echo "openrouter|deepseek/deepseek-v4-pro"
            ;;
        tier:frontier)  # codex (gpt-5.5, subscription) is frontier-class + free; GLM-5.2 fallback.
            # NOT OpenRouter Opus — that was the expensive default. Opus is explicit-only (--model opus).
            echo "codex_cli|"
            echo "openrouter|z-ai/glm-5.2"
            ;;
        # --- shorthands (first positional arg) ---
        short:flash|short:dsf|short:deepseek-flash)
            echo "deepseek|deepseek-v4-flash"; echo "openrouter|deepseek/deepseek-v4-flash" ;;
        short:deepseek|short:ds)
            echo "deepseek|deepseek-v4-pro"; echo "openrouter|deepseek/deepseek-v4-pro" ;;
        short:glm)
            echo "zai|glm-5.2"; echo "openrouter|z-ai/glm-5.2" ;;
        short:glm-turbo)
            echo "zai|glm-5-turbo" ;;
        short:grok)        echo "openrouter|x-ai/grok-4.3" ;;
        short:gemini)      echo "openrouter|~google/gemini-pro-latest" ;;  # via OR: direct key is stale
        short:gemini-flash) echo "openrouter|~google/gemini-flash-latest" ;;
        short:gpt|short:codex)  # ChatGPT subscription via codex CLI, then OpenRouter
            echo "codex_cli|"; echo "openrouter|~openai/gpt-latest" ;;
        short:mini|short:gpt-mini) echo "openrouter|~openai/gpt-mini-latest" ;;
        short:claude|short:opus)   # Claude subscription via claude CLI, then OpenRouter Opus 4.8 (pinned)
            echo "claude_cli|opus"; echo "openrouter|anthropic/claude-opus-4.8" ;;
        short:sonnet)      echo "claude_cli|sonnet"; echo "openrouter|~anthropic/claude-sonnet-latest" ;;
        short:haiku)       echo "claude_cli|haiku"; echo "openrouter|~anthropic/claude-haiku-latest" ;;
        short:qwen)        echo "openrouter|qwen/qwen3.6-plus" ;;
        short:mistral)     echo "openrouter|mistralai/mistral-medium-3-5" ;;
        # --- explicit --model VALUE ---
        explicit:*)
            spec="${1#explicit:}"
            if [[ "$spec" == *:* && "$spec" != *://* ]]; then
                # provider:model form, e.g. deepseek:deepseek-v4-pro
                echo "${spec%%:*}|${spec#*:}"
            else
                # bare id -> OpenRouter
                echo "openrouter|$spec"
            fi
            ;;
        *) echo "" ;;
    esac
}

is_shorthand() {
    # Returns 0 if the token is a known shorthand selector.
    [ -n "$(resolve_routes "short:$1")" ]
}

# ----------------------------------------------------------------------------
SYSTEM_DEFAULT="Be concise. No preamble, no closing remarks. Answer directly. Prefer working code over explanation. Give the simplest solution that works."
SYSTEM="$SYSTEM_DEFAULT"
SELECTOR="tier:default"
TEMPERATURE="0.7"
MAX_TOKENS="8000"
REQUEST_TIMEOUT="${AGENT_TIMEOUT:-180}"
MAX_RETRIES="${AGENT_RETRIES:-2}"
NO_FALLBACK=0
SHOW_USAGE=1
PROMPT_ARGS=()
INPUT_FILES=()
READ_STDIN="auto"
VERBOSE=0
DRY_RUN=0

show_usage() {
    cat <<'USAGE'
Usage: agent [OPTIONS] [SHORTHAND] "your question"
       agent [OPTIONS] --file packet.md "review this packet"
       git diff | agent [OPTIONS] "review this diff"

Routing: each tier/shorthand resolves to an ordered list of provider routes.
The cheapest available route is tried first; transient errors retry with
backoff; rejected keys and unavailable models fall through to the next route.

Input behavior:
  Positional text becomes the main prompt.
  Piped stdin is appended automatically, even when a prompt is present.
  --file/-f PATH may be repeated; each file is appended with a filename header.

Options:
  --fast              Fast + cheap tier (deepseek-v4-flash)
  --smart             Strong-reasoning tier (GLM / DeepSeek pro)
  --frontier          codex subscription (gpt-5.5, free) -> GLM-5.2 fallback
  --model ID          Explicit model. Bare id -> OpenRouter; or provider:model
                      (e.g. deepseek:deepseek-v4-pro, zai:glm-5-turbo)
  --no-fallback       Try only the first resolved route; do not fall through
  --retries N         Max retries per route on transient errors (default 2)
  --no-usage          Suppress the token/cost readout on stderr
  --file, -f PATH     Append file contents (aliases: --input, --context, --prompt-file; - for stdin)
  --stdin             Require and append stdin, even with prompt/files
  --no-stdin          Ignore piped stdin
  --system TEXT       Override system prompt
  --temperature N     Sampling temperature (default 0.7)
  --max-tokens N      Max completion tokens (default 8000)
  --timeout N         HTTP request timeout seconds (default 180; env AGENT_TIMEOUT)
  --verbose           Print routing/input summary to stderr before calling
  --dry-run           Print routing summary and final prompt; do not call any API
  -h, --help          Show this help

Premium models route to your local SUBSCRIPTION CLI first (no per-token
cost), then fall back to OpenRouter if the CLI is missing or not logged in:
  opus/sonnet/haiku -> `claude` CLI      gpt/codex -> `codex` CLI

Tiers (cheap-first):
  (default)     codex subscription (gpt-5.5, free) -> GLM-5.2 fallback
  --fast        deepseek-v4-flash direct -> OpenRouter (fast + cheap, for bulk)
  --smart       Z.AI glm-5.2 -> deepseek-v4-pro
  --frontier    codex subscription (gpt-5.5, free) -> GLM-5.2 fallback
                (Opus is explicit-only: --model opus / `agent opus ...`)

Model shorthands (first positional arg):
  flash, dsf    deepseek-v4-flash (direct)
  deepseek, ds  deepseek-v4-pro (direct)
  glm           Z.AI glm-5.1            glm-turbo  Z.AI glm-5-turbo
  grok          x-ai/grok-4.3           gemini     gemini-pro (via OpenRouter)
  gpt, codex    ChatGPT via codex CLI   mini       gpt-mini (OpenRouter)
  claude, opus  Claude Opus via CLI     sonnet / haiku  via claude CLI
  qwen          qwen3.6-plus            mistral    mistral-medium-3-5

Examples:
  agent "What is the time complexity of quicksort?"
  agent --fast "blunt take on this idea"
  agent glm "Explain the CAP theorem"
  agent --model deepseek:deepseek-v4-pro "Design a rate limiter"
  agent --file review-packet.md --smart "Find concrete bugs"
  git diff | agent deepseek "Review these changes"
  agent --frontier --no-fallback "Hard architecture call, best model only"
USAGE
}

need_value() {
    local opt="$1"
    if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
        echo "Error: ${opt} requires a value" >&2
        exit 2
    fi
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --fast)        SELECTOR="tier:fast"; shift ;;
        --smart)       SELECTOR="tier:smart"; shift ;;
        --frontier)    SELECTOR="tier:frontier"; shift ;;
        --model)       need_value "$1" "${2:-}"; SELECTOR="explicit:$2"; shift 2 ;;
        --model=*)     SELECTOR="explicit:${1#*=}"; shift ;;
        --no-fallback) NO_FALLBACK=1; shift ;;
        --retries)     need_value "$1" "${2:-}"; MAX_RETRIES="$2"; shift 2 ;;
        --retries=*)   MAX_RETRIES="${1#*=}"; shift ;;
        --no-usage)    SHOW_USAGE=0; shift ;;
        -f|--file|--input|--context|--prompt-file) need_value "$1" "${2:-}"; INPUT_FILES+=("$2"); shift 2 ;;
        --file=*|--input=*|--context=*|--prompt-file=*) INPUT_FILES+=("${1#*=}"); shift ;;
        --stdin)       READ_STDIN="yes"; shift ;;
        --no-stdin)    READ_STDIN="no"; shift ;;
        --system)      need_value "$1" "${2:-}"; SYSTEM="$2"; shift 2 ;;
        --system=*)    SYSTEM="${1#*=}"; shift ;;
        --temperature) need_value "$1" "${2:-}"; TEMPERATURE="$2"; shift 2 ;;
        --temperature=*) TEMPERATURE="${1#*=}"; shift ;;
        --max-tokens)  need_value "$1" "${2:-}"; MAX_TOKENS="$2"; shift 2 ;;
        --max-tokens=*) MAX_TOKENS="${1#*=}"; shift ;;
        --timeout)     need_value "$1" "${2:-}"; REQUEST_TIMEOUT="$2"; shift 2 ;;
        --timeout=*)   REQUEST_TIMEOUT="${1#*=}"; shift ;;
        --verbose)     VERBOSE=1; shift ;;
        --dry-run)     DRY_RUN=1; shift ;;
        -h|--help)     show_usage; exit 0 ;;
        --)            shift; PROMPT_ARGS+=("$@"); break ;;
        -*)            echo "Error: unknown option: $1" >&2; show_usage >&2; exit 2 ;;
        @*)
            file="${1#@}"
            if [ -r "$file" ]; then
                INPUT_FILES+=("$file"); shift
            else
                echo "Error: @file not readable: $file" >&2; exit 2
            fi
            ;;
        *)             PROMPT_ARGS+=("$1"); shift ;;
    esac
done

# Resolve a leading shorthand from the first positional arg (only if a tier
# wasn't explicitly chosen via --fast/--smart/--frontier/--model).
if [ ${#PROMPT_ARGS[@]} -gt 0 ] && [ "$SELECTOR" = "tier:default" ]; then
    if is_shorthand "${PROMPT_ARGS[0]}"; then
        SELECTOR="short:${PROMPT_ARGS[0]}"
        PROMPT_ARGS=("${PROMPT_ARGS[@]:1}")
    fi
fi

append_section() {
    local current="$1" title="$2" body="$3"
    if [ -z "$body" ]; then printf '%s' "$current"; return; fi
    if [ -n "$current" ]; then
        printf '%s\n\n--- %s ---\n%s' "$current" "$title" "$body"
    else
        printf -- '--- %s ---\n%s' "$title" "$body"
    fi
}

QUESTION=""
if [ ${#PROMPT_ARGS[@]} -gt 0 ]; then
    QUESTION="${PROMPT_ARGS[*]}"
fi

for file in "${INPUT_FILES[@]+"${INPUT_FILES[@]}"}"; do
    if [ "$file" = "-" ]; then
        if [ -t 0 ]; then
            echo "Error: --file - requested stdin, but stdin is a TTY" >&2; exit 2
        fi
        content=$(cat)
        QUESTION=$(append_section "$QUESTION" "stdin" "$content")
        READ_STDIN="no"
    elif [ ! -r "$file" ]; then
        echo "Error: cannot read file: $file" >&2; exit 2
    else
        content=$(cat "$file")
        QUESTION=$(append_section "$QUESTION" "file: $file" "$content")
    fi
done

if [ "$READ_STDIN" != "no" ]; then
    if [ ! -t 0 ]; then
        stdin_content=$(cat)
        if [ -n "$stdin_content" ]; then
            QUESTION=$(append_section "$QUESTION" "stdin" "$stdin_content")
        elif [ "$READ_STDIN" = "yes" ]; then
            echo "Error: --stdin requested, but stdin was empty" >&2; exit 2
        fi
    elif [ "$READ_STDIN" = "yes" ]; then
        echo "Error: --stdin requested, but stdin is a TTY" >&2; exit 2
    fi
fi

if [ -z "$QUESTION" ]; then
    show_usage >&2; exit 1
fi

case "$MAX_TOKENS" in
    ''|*[!0-9]*) echo "Error: --max-tokens must be a positive integer" >&2; exit 2 ;;
esac
[ "$MAX_TOKENS" -le 0 ] && { echo "Error: --max-tokens must be a positive integer" >&2; exit 2; }
case "$MAX_RETRIES" in
    ''|*[!0-9]*) echo "Error: --retries must be a non-negative integer" >&2; exit 2 ;;
esac

set +e
python3 - "$TEMPERATURE" "$REQUEST_TIMEOUT" <<'PY' >/dev/null
import math, sys
try:
    temperature = float(sys.argv[1]); timeout = float(sys.argv[2])
except ValueError:
    sys.exit(2)
if not math.isfinite(temperature) or temperature < 0: sys.exit(3)
if not math.isfinite(timeout) or timeout <= 0: sys.exit(4)
PY
validation_rc=$?
set -e
case "$validation_rc" in
    0) ;;
    2) echo "Error: --temperature and --timeout must be numeric" >&2; exit 2 ;;
    3) echo "Error: --temperature must be a finite non-negative number" >&2; exit 2 ;;
    4) echo "Error: --timeout must be a positive number of seconds" >&2; exit 2 ;;
    *) echo "Error: option validation failed" >&2; exit 2 ;;
esac

# Resolve routes, honoring --no-fallback.
ROUTES="$(resolve_routes "$SELECTOR")"
if [ -z "$ROUTES" ]; then
    echo "Error: could not resolve any route for selector '$SELECTOR'" >&2; exit 2
fi
if [ "$NO_FALLBACK" -eq 1 ]; then
    ROUTES="$(printf '%s\n' "$ROUTES" | head -1)"
fi

question_chars=$(printf '%s' "$QUESTION" | wc -c | tr -d ' ')
if [ "$VERBOSE" -eq 1 ] || [ "$DRY_RUN" -eq 1 ]; then
    {
        echo "agent: selector=${SELECTOR}"
        echo "agent: routes=$(printf '%s' "$ROUTES" | tr '\n' ',' | sed 's/,$//')"
        echo "agent: prompt_bytes=${question_chars} files=${#INPUT_FILES[@]} stdin_mode=${READ_STDIN}"
        echo "agent: max_tokens=${MAX_TOKENS} temperature=${TEMPERATURE} timeout=${REQUEST_TIMEOUT} retries=${MAX_RETRIES}"
    } >&2
fi

if [ "$DRY_RUN" -eq 1 ]; then
    printf '%s\n' "$QUESTION"
    exit 0
fi

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT
printf '%s' "$QUESTION" > "$tmpdir/question.txt"
printf '%s' "$SYSTEM" > "$tmpdir/system.txt"

# Optional wall-clock guard for CLI providers (agentic CLIs can hang).
TIMEOUT_BIN="$(command -v timeout || command -v gtimeout || true)"

build_payload() {  # $1=model -> writes $tmpdir/payload.json
    python3 - "$1" "$TEMPERATURE" "$MAX_TOKENS" "$tmpdir/system.txt" "$tmpdir/question.txt" > "$tmpdir/payload.json" <<'PY'
import json, sys
model, temperature, max_tokens, system_path, question_path = sys.argv[1:]
with open(system_path, encoding="utf-8") as f: system = f.read()
with open(question_path, encoding="utf-8") as f: question = f.read()
print(json.dumps({
    "model": model,
    "messages": [
        {"role": "system", "content": system},
        {"role": "user", "content": question},
    ],
    "temperature": float(temperature),
    "max_tokens": int(max_tokens),
}))
PY
}

# Parse a successful response: content -> stdout, usage/cost -> stderr.
# Exit 0 on usable content, 5 on empty/malformed (caller treats as route failure).
parse_success() {  # $1=label $2=response_path $3=price_in $4=price_out $5=show_usage
    python3 - "$@" <<'PY'
import json, sys
label, response_path, price_in, price_out, show_usage = sys.argv[1:]
try:
    with open(response_path, encoding="utf-8") as f:
        data = json.load(f)
    content = data["choices"][0]["message"]["content"] or ""
except Exception:
    sys.exit(5)
if not content.strip():
    sys.exit(5)
print(content)
if show_usage == "1":
    u = data.get("usage", {}) or {}
    pin = u.get("prompt_tokens"); pout = u.get("completion_tokens")
    parts = [f"agent ✓ {label}"]
    if pin is not None or pout is not None:
        parts.append(f"in={pin or 0} out={pout or 0}")
    try:
        if price_in and price_out and (pin is not None) and (pout is not None):
            cost = pin/1e6*float(price_in) + pout/1e6*float(price_out)
            parts.append(f"~${cost:.4f}")
    except Exception:
        pass
    print(" · ".join(parts), file=sys.stderr)
PY
}

# Try a single route with retries+backoff.
# Returns: 0 success, 1 rejected-credential, 2 transient-exhausted, 3 route-error.
try_route() {
    local provider="$1" model="$2"
    local base_url key_env key attempt http_code curl_rc backoff
    base_url="$(provider_base_url "$provider")"
    key_env="$(provider_key_env "$provider")"
    if [ -z "$base_url" ] || [ -z "$key_env" ]; then
        echo "agent: unknown provider '$provider' — skipping" >&2; return 3
    fi
    key="${!key_env:-}"
    if [ -z "$key" ]; then
        [ "$VERBOSE" -eq 1 ] && echo "agent: skip ${provider} (${key_env} unset)" >&2
        return 3
    fi
    build_payload "$model"

    attempt=0
    while :; do
        http_code=$(curl -sS -o "$tmpdir/response.json" -w '%{http_code}' "$base_url" \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${key}" \
            -H "HTTP-Referer: https://claude.ai" \
            -H "X-Title: Claude Code" \
            --connect-timeout 10 \
            --max-time "$REQUEST_TIMEOUT" \
            --data-binary "@$tmpdir/payload.json" 2>/dev/null)
        curl_rc=$?

        # Network/timeout failure from curl itself -> transient.
        if [ "$curl_rc" -ne 0 ]; then
            if [ "$attempt" -lt "$MAX_RETRIES" ]; then
                backoff=$((1 << attempt)); attempt=$((attempt + 1))
                [ "$VERBOSE" -eq 1 ] && echo "agent: ${provider}/${model} network error (curl $curl_rc), retry ${attempt}/${MAX_RETRIES} in ${backoff}s" >&2
                sleep "$backoff"; continue
            fi
            echo "agent: ${provider}/${model} unreachable (curl exit $curl_rc)" >&2
            return 2
        fi

        case "$http_code" in
            2??)
                local pin pout price label
                price="$(price_for "${provider}|${model}")"
                pin="${price%% *}"; pout="${price##* }"
                [ "$price" = "" ] && { pin=""; pout=""; }
                label="${provider}/${model}"
                if parse_success "$label" "$tmpdir/response.json" "$pin" "$pout" "$SHOW_USAGE"; then
                    return 0
                fi
                echo "agent: ${label} returned empty/malformed content" >&2
                return 3
                ;;
            401|403)
                echo "agent: ${provider} credential rejected (HTTP ${http_code}, ${key_env} present but invalid) — skipping provider" >&2
                return 1
                ;;
            429|5??)
                if [ "$attempt" -lt "$MAX_RETRIES" ]; then
                    backoff=$((1 << attempt)); attempt=$((attempt + 1))
                    [ "$VERBOSE" -eq 1 ] && echo "agent: ${provider}/${model} HTTP ${http_code}, retry ${attempt}/${MAX_RETRIES} in ${backoff}s" >&2
                    sleep "$backoff"; continue
                fi
                echo "agent: ${provider}/${model} HTTP ${http_code} after ${MAX_RETRIES} retries" >&2
                return 2
                ;;
            *)
                local msg
                msg=$(python3 -c 'import json,sys
try:
    d=json.load(open(sys.argv[1]))
    e=d.get("error",d); print(e.get("message") if isinstance(e,dict) else str(e))
except Exception: print("")' "$tmpdir/response.json" 2>/dev/null)
                echo "agent: ${provider}/${model} HTTP ${http_code}: ${msg:-unexpected response}" >&2
                return 3
                ;;
        esac
    done
}

# Run a CLI-transport route via a locally-authenticated subscription tool.
# No per-token cost, so the readout shows "subscription" instead of $.
# Returns: 0 success, 2 failed (not installed / not logged in / timed out).
run_cli_route() {
    local provider="$1" model="$2" bin out rc label errmsg
    case "$provider" in
        claude_cli) bin="claude" ;;
        codex_cli)  bin="codex" ;;
        *) return 3 ;;
    esac
    if ! command -v "$bin" >/dev/null 2>&1; then
        [ "$VERBOSE" -eq 1 ] && echo "agent: skip ${provider} (${bin} not installed)" >&2
        return 3
    fi
    label="${provider%_cli}${model:+/$model}"

    # Caller wraps this in `set +e`; do not toggle errexit here (it would leak).
    case "$provider" in
        claude_cli)
            # Question on stdin; replace the default coding-agent system prompt.
            if [ -n "$TIMEOUT_BIN" ]; then
                out=$("$TIMEOUT_BIN" "$REQUEST_TIMEOUT" claude -p --model "$model" \
                        --system-prompt "$SYSTEM" < "$tmpdir/question.txt" 2>"$tmpdir/cli.err")
            else
                out=$(claude -p --model "$model" --system-prompt "$SYSTEM" \
                        < "$tmpdir/question.txt" 2>"$tmpdir/cli.err")
            fi
            rc=$?
            ;;
        codex_cli)
            # codex exec has no system flag; prepend system to the prompt.
            { cat "$tmpdir/system.txt"; printf '\n\n'; cat "$tmpdir/question.txt"; } > "$tmpdir/cli.in"
            if [ -n "$TIMEOUT_BIN" ]; then
                "$TIMEOUT_BIN" "$REQUEST_TIMEOUT" codex exec - -o "$tmpdir/cli.out" --color never \
                    ${model:+-m "$model"} < "$tmpdir/cli.in" >/dev/null 2>"$tmpdir/cli.err"
            else
                codex exec - -o "$tmpdir/cli.out" --color never \
                    ${model:+-m "$model"} < "$tmpdir/cli.in" >/dev/null 2>"$tmpdir/cli.err"
            fi
            rc=$?
            out=$(cat "$tmpdir/cli.out" 2>/dev/null)
            ;;
    esac

    if [ "$rc" -ne 0 ] || [ -z "$out" ]; then
        errmsg=$(tail -1 "$tmpdir/cli.err" 2>/dev/null)
        echo "agent: ${label} via ${bin} CLI failed (exit ${rc})${errmsg:+: ${errmsg}}" >&2
        return 2
    fi
    printf '%s\n' "$out"
    [ "$SHOW_USAGE" -eq 1 ] && echo "agent ✓ ${label} · subscription (${bin} CLI)" >&2
    return 0
}

# Walk the route list; first success wins. Herestring keeps this in-shell
# (no subshell) so state survives the loop.
attempted=0
while IFS= read -r route; do
    [ -z "$route" ] && continue
    provider="${route%%|*}"; model="${route#*|}"
    attempted=$((attempted + 1))
    set +e
    if [ "$(provider_transport "$provider")" = "cli" ]; then
        run_cli_route "$provider" "$model"
    else
        try_route "$provider" "$model"
    fi
    rc=$?
    set -e
    if [ "$rc" -eq 0 ]; then
        exit 0
    fi
    # rc 1/2/3 -> fall through to the next candidate.
done <<< "$ROUTES"

echo "Error: all ${attempted} route(s) failed for selector '${SELECTOR}'." >&2
echo "       Check ~/.secrets keys, model availability, or run with --verbose." >&2
exit 1
